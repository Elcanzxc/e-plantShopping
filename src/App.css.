/* Стили для посадочной страницы Paradise Nursery */
.landing-page {
    background-image: url('https://images.unsplash.com/photo-1466781783364-391e6e6d2c74');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    height: 100vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
}

/* Дополнительные стили для читаемости текста на фоне */
.content {
    background-color: rgba(0, 0, 0, 0.5); /* Полупрозрачный темный слой */
    padding: 20px;
    border-radius: 10px;
}
